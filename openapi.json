{
  "openapi": "3.1.0",
  "info": {
    "title": "tldraw self-host board API",
    "version": "0.1.0",
    "description": "REST API for synced tldraw boards. Protected endpoints accept either a Clerk organization JWT for human sessions or a Board workspace token for agents and integrations."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "health",
        "summary": "Check service health",
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        }
      }
    },
    "/api/boards": {
      "get": {
        "operationId": "listBoards",
        "summary": "List boards visible in the authenticated workspace",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Known boards"
          }
        }
      }
    },
    "/api/boards/{roomId}": {
      "get": {
        "operationId": "readBoard",
        "summary": "Read board records grouped by type",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Board records"
          }
        }
      },
      "patch": {
        "operationId": "renameBoard",
        "summary": "Rename a board",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated board metadata"
          }
        }
      },
      "delete": {
        "operationId": "deleteBoard",
        "summary": "Delete a board and its persisted room data",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Board deleted"
          }
        }
      }
    },
    "/api/boards/{roomId}/snapshot": {
      "get": {
        "operationId": "getBoardSnapshot",
        "summary": "Read the full tldraw sync room snapshot",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Room snapshot"
          }
        }
      }
    },
    "/api/boards/{roomId}/records": {
      "post": {
        "operationId": "createOrUpdateRecords",
        "summary": "Create or update raw tldraw records",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["records"],
                "properties": {
                  "records": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records written"
          }
        }
      },
      "delete": {
        "operationId": "deleteRecords",
        "summary": "Delete records by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["recordIds"],
                "properties": {
                  "recordIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records deleted"
          }
        }
      }
    },
    "/api/integration-tokens": {
      "post": {
        "operationId": "createIntegrationToken",
        "summary": "Create a scoped Board workspace token for agents or integrations",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string",
                    "enum": ["editor", "viewer"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created. The token value is returned once."
          }
        }
      }
    },
    "/mcp": {
      "post": {
        "operationId": "mcp",
        "summary": "MCP Streamable HTTP endpoint",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "MCP response"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT or Board workspace token",
        "description": "Use a Clerk organization JWT for browser/user-scoped calls or a bd_ Board workspace token for agent integrations."
      }
    }
  }
}
